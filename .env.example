# ── IA (Anthropic) ──────────────────────────────────────────────────────────
# Usada en el navegador (features de IA) y en la Vercel Function (cron de notificaciones)
VITE_ANTHROPIC_API_KEY=tu_clave_anthropic_aqui
ANTHROPIC_API_KEY=tu_clave_anthropic_aqui   # misma clave, para la Vercel Function

# ── Push Notifications (OneSignal) ──────────────────────────────────────────
ONESIGNAL_APP_ID=d19fd9ea-3350-445b-a6f1-daca17fc9cb9
ONESIGNAL_REST_API_KEY=tu_rest_api_key_de_onesignal_aqui

# ── Seguridad del cron (opcional) ───────────────────────────────────────────
# Si se define, la Function exige Authorization: Bearer <CRON_SECRET> en llamadas manuales
CRON_SECRET=una_cadena_secreta_aleatoria
